{
  "name": "training_logs",
  "description": "训练日志集合",
  "version": "1.0.0",
  "properties": {
    "_id": { "type": "string" },
    "_openid": { "type": "string" },
    "plan_id": { "type": "string", "description": "关联的训练计划ID" },
    "workout_date": { "type": "string", "description": "训练日期 YYYY-MM-DD" },
    "planned_type": { "type": "string" },
    "planned_distance_km": { "type": "number" },
    "planned_pace_sec_per_km": { "type": "number" },
    "completion_status": { "type": "string", "enum": ["done", "partial", "skipped"] },
    "actual_distance_km": { "type": "number" },
    "actual_duration_sec": { "type": "number" },
    "actual_pace_sec_per_km": { "type": "number" },
    "actual_avg_hr": { "type": "number" },
    "self_rating": { "type": "number", "minimum": 1, "maximum": 5 },
    "difficulty_rating": { "type": "number", "minimum": 1, "maximum": 3 },
    "feeling_note": { "type": "string" },
    "synced_from": { "type": "string" },
    "is_pb": { "type": "boolean", "default": false },
    "pb_detail": { "type": "object" },
    "created_at": { "type": "string" }
  },
  "required": ["_openid", "workout_date"],
  "indexes": [
    { "name": "openid_date_idx", "keys": ["_openid", "workout_date"] },
    { "name": "plan_id_idx", "keys": ["plan_id"] }
  ]
}
