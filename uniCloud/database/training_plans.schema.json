{
  "name": "training_plans",
  "description": "训练计划集合",
  "version": "1.0.0",
  "properties": {
    "_id": { "type": "string" },
    "_openid": { "type": "string", "description": "微信OpenID" },
    "plan_name": { "type": "string", "description": "计划名称" },
    "goal_distance": { "type": "string", "enum": ["5k", "10k", "half_marathon", "marathon"] },
    "goal_time_sec": { "type": "number" },
    "race_date": { "type": "string" },
    "total_weeks": { "type": "number" },
    "start_date": { "type": "string" },
    "current_week": { "type": "number", "default": 1 },
    "current_phase": { "type": "string" },
    "phases": { "type": "array", "description": "训练周期阶段" },
    "weeks": { "type": "array", "description": "每周训练数据(嵌入式)" },
    "status": { "type": "string", "enum": ["active", "completed", "paused"], "default": "active" },
    "ai_generated_by": { "type": "string" },
    "created_at": { "type": "string" },
    "updated_at": { "type": "string" }
  },
  "required": ["_openid"],
  "indexes": [
    { "name": "openid_status_idx", "keys": ["_openid", "status"] }
  ]
}
